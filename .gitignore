# ==============================================
# 编译产物 & 中间文件
# ==============================================
# Visual Studio 编译目录
x64/
Debug/
Release/

# 编译生成的对象文件和日志
*.obj
*.ilk
*.log
*.tlog
*.recipe
*.FileListAbsolute.txt

# 调试与数据库文件
*.idb
*.pdb

# 可执行文件与库文件
*.exe
*.dll
*.lib

# ==============================================
# IDE & 编辑器临时文件
# ==============================================
.vs/
.vscode/
*.suo
*.user
*.sln.docstates

# ==============================================
# 操作系统生成的文件
# ==============================================
Thumbs.db
.DS_Store

# ==============================================
# 保留你需要上传的文件
# ==============================================
# 允许上传 .cpp 源代码
!*.cpp

# 允许上传 .csv 数据文件
!*.csv

# 允许上传 .sln 项目文件
!*.sln